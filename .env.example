# Optional. Used only by seed/info scripts, never by the running web service.
FILECOIN_PRIVATE_KEY=0x...

# Optional server settings.
PORT=3000
HOST=127.0.0.1
PROOFHOOK_WEBHOOK_SECRET=replace-with-a-long-random-secret
PROOFHOOK_DEMO_WEBHOOK_URL=http://127.0.0.1:3000/demo/receiver
PROOFHOOK_RECEIPT_PATH=data/demo-receipt.json
PROOFHOOK_DELIVERY_LOG_PATH=data/delivery-log.json
PROOFHOOK_ALLOW_PRIVATE_WEBHOOK_URLS=true
PROOFHOOK_SCHEDULE_SECONDS=0
PROOFHOOK_ADMIN_KEY=

# Explicit providers avoid the SDK's 1-second auto-selection ping timeout on high-latency links.
# Provider 4 is endorsed; provider 2 is approved on Calibration as of 2026-07-16.
PROOFHOOK_PROVIDER_IDS=4,2
