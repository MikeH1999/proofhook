{
  "name": "proofhook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Turn Filecoin Onchain Cloud health into signed webhooks.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start:prod": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts",
    "verify": "npm run typecheck && npm test && npm run build && npm audit --audit-level=high",
    "verify:live": "npm run verify && npm run check:piece",
    "wallet:info": "tsx scripts/wallet-info.ts",
    "providers:info": "tsx scripts/providers-info.ts",
    "seed": "tsx scripts/seed-demo.ts",
    "check:piece": "tsx scripts/check-piece.ts",
    "send:event": "tsx scripts/send-event.ts"
  },
  "dependencies": {
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "@filoz/synapse-core": "^0.7.0",
    "@filoz/synapse-sdk": "^1.1.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "viem": "^2.38.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
